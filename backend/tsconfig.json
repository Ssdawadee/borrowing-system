{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "src/app.ts",
    "src/express.d.ts",
    "src/types.ts",
    "src/config/**/*.ts",
    "src/middleware/**/*.ts",
    "src/routes/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}